{
  flake.modules.homeManager.@ASPECT_NAME@ =
    { lib, pkgs, ... }:
    lib.mkMerge [
      {
        home.packages = with pkgs; [
        ];
      }
      (lib.mkIf pkgs.stdenv.isLinux {
        home.packages = with pkgs; [
        ];
      })
      (lib.mkIf pkgs.stdenv.isDarwin {
        home.packages = with pkgs; [
        ];
      })
    ];
}
